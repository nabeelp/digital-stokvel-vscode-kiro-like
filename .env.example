# Digital Stokvel Banking - Environment Variables
# Copy this file to .env and replace with secure passwords
# NEVER commit .env to version control!

# PostgreSQL Primary Database
POSTGRES_USER=stokvel_admin
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=digitalstokvel

# PostgreSQL Ledger Database (Append-Only)
POSTGRES_LEDGER_USER=ledger_admin
POSTGRES_LEDGER_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_LEDGER_DB=digitalstokvel_ledger

# Redis Cache
REDIS_PASSWORD=CHANGE_THIS_PASSWORD

# RabbitMQ Message Queue
RABBITMQ_USER=stokvel_admin
RABBITMQ_PASSWORD=CHANGE_THIS_PASSWORD

# pgAdmin (PostgreSQL Management UI)
PGADMIN_EMAIL=admin@digitalstokvel.local
PGADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# Development Quick Setup (INSECURE - For local dev only!)
# Uncomment these ONLY for initial local setup, then replace with secure passwords
# POSTGRES_PASSWORD=Dev@Password123
# POSTGRES_LEDGER_PASSWORD=Dev@Password123
# REDIS_PASSWORD=Dev@Password123
# RABBITMQ_PASSWORD=Dev@Password123
# PGADMIN_PASSWORD=Dev@Password123
