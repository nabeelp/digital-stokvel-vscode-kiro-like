{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyForDigitalStokvel2026MustBeAtLeast32CharactersLong",
    "Issuer": "stokvel-api",
    "Audience": "stokvel-clients",
    "ExpirationMinutes": 1440,
    "RefreshTokenExpirationDays": 30
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      }
    ]
  },

  "ClientRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "EndpointWhitelist": [ "get:/health" ],
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      },
      {
        "Endpoint": "post:/api/v1/auth/login",
        "Period": "5m",
        "Limit": 5
      }
    ]
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/auth/{**catch-all}"
          }
        ]
      },
      "groups-route": {
        "ClusterId": "groups-cluster",
        "AuthorizationPolicy": "RequireMember",
        "Match": {
          "Path": "/api/v1/groups/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/groups/{**catch-all}"
          }
        ]
      },
      "contributions-route": {
        "ClusterId": "contributions-cluster",
        "AuthorizationPolicy": "RequireMember",
        "Match": {
          "Path": "/api/v1/contributions/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/contributions/{**catch-all}"
          }
        ]
      },
      "payouts-route": {
        "ClusterId": "payouts-cluster",
        "AuthorizationPolicy": "RequireFinancialRole",
        "Match": {
          "Path": "/api/v1/payouts/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/payouts/{**catch-all}"
          }
        ]
      },
      "governance-route": {
        "ClusterId": "governance-cluster",
        "AuthorizationPolicy": "RequireMember",
        "Match": {
          "Path": "/api/v1/governance/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/governance/{**catch-all}"
          }
        ]
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "AuthorizationPolicy": "RequireMember",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/notifications/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://auth-service:8080"
          }
        }
      },
      "groups-cluster": {
        "Destinations": {
          "groups-service": {
            "Address": "http://groups-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "contributions-cluster": {
        "Destinations": {
          "contributions-service": {
            "Address": "http://contributions-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "payouts-cluster": {
        "Destinations": {
          "payouts-service": {
            "Address": "http://payouts-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "governance-cluster": {
        "Destinations": {
          "governance-service": {
            "Address": "http://governance-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "notifications-service": {
            "Address": "http://notifications-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  }
}
