# .dockerignore
# Exclude files and directories that should not be sent to the Docker daemon during build

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.github/
.azure/
azure-pipelines.yml

# Documentation
*.md
LICENSE
docs/
.kiro-like/

# IDE and Editor
.vs/
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.sln.docstates
*.DotSettings.user

# Build results
**/bin/
**/obj/
**/out/
**/publish/
**/TestResults/

# NuGet
*.nupkg
*.snupkg

# Test Coverage
**/coverage/
**/*.coverage
**/*.coveragexml

# Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Environment variables
.env
.env.local
.env.*.local
!.env.example

# Docker
**/Dockerfile
**/.dockerignore
**/docker-compose*.yml
**/compose*.yml

# Scripts (not needed in container)
scripts/

# Infrastructure (not needed in container)
infrastructure/

# Tests (already built and published)
**/tests/
**/*.Tests/
**/*.IntegrationTests/

# Temporary files
**/tmp/
**/temp/
**/*.tmp
**/*.temp
**/*.swp
**/*.bak

# Database
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Kubernetes
*.yaml
*.yml
!appsettings*.json
!appsettings*.yml

# Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
